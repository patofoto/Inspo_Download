{
  "manifest_version": 3,
  "name": "Image Downloader to Network Drive",
  "version": "1.0",
  "description": "Right-click on images to download them to your network drive",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "action": {},
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "48": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
